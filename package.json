{
  "name": "apex",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "backtest:comprehensive": "pnpm --filter @apex/api backtest:comprehensive",
    "backtest": "pnpm --filter @apex/api backtest",
    "backtest:analyze": "pnpm --filter @apex/api analyze-backtest",
    "backtest:compare": "pnpm --filter @apex/api compare-backtest"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "msgpackr-extract"
    ]
  }
}
