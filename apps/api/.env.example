# Redis (ioredis connection string — for BullMQ job queues)
REDIS_URL="redis-cli --tls -u redis://default:gQAAAAAAARG-AAIncDFiNzExMzZjYTdjMjI0YzAzOWU0NTJjYTE4ODBhMzYzZnAxNzAwNzg@advanced-ostrich-70078.upstash.io:6379"

# Auth
