{
  "name": "@apex/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/apps/api/src/index.js",
    "check-types": "tsc --noEmit",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "import:historical": "tsx src/engine/import-historical.ts",
    "import:mt5": "tsx src/engine/import-mt5.ts",
    "import:targeted": "tsx src/engine/import-targeted.ts",
    "import:dukascopy": "tsx src/engine/import-dukascopy.ts",
    "check:data": "tsx src/check-data.ts",
    "backtest": "tsx src/engine/backtest.ts",
    "backtest:comprehensive": "tsx src/engine/backtest-comprehensive.ts",
    "backtest:live": "tsx src/engine/backtest-live-logic.ts",
    "analyze-backtest": "tsx src/engine/analyze-backtest.ts",
    "compare-backtest": "tsx src/engine/compare-backtest.ts",
    "backtest:param-test": "tsx src/engine/quick-param-test.ts",
    "test:phase3": "tsx src/engine/test-phase3.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run tests/e2e.test.ts",
    "test:signal": "vitest run tests/signal-pipeline.test.ts"
  },
  "dependencies": {
    "@apex/types": "workspace:*",
    "@fastify/cors": "^10.0.1",
    "@fastify/jwt": "^9.0.1",
    "@fastify/rate-limit": "^10.2.1",
    "@fastify/websocket": "^11.2.0",
    "@supabase/supabase-js": "^2.47.10",
    "@upstash/redis": "^1.34.3",
    "axios": "^1.14.0",
    "bullmq": "^5.34.8",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.3",
    "fastify": "^5.2.1",
    "groq-sdk": "^1.1.2",
    "jsonwebtoken": "^9.0.3",
    "postgres": "^3.4.5",
    "ws": "^8.20.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@apex/config": "workspace:*",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.5",
    "@types/ws": "^8.18.1",
    "@vitest/ui": "^1.6.0",
    "drizzle-kit": "^0.30.1",
    "dukascopy-node": "^1.46.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^1.6.0"
  }
}
